generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  username     String   @unique
  email        String   @unique
  phone        String
  password     String
  institution  String
  createdAt    DateTime @default(now())
}